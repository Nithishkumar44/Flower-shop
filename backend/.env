# Server Configurations
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flower_db?schema=public"

# Authentication Secrets
JWT_SECRET="luxurious_floral_secret_key_change_me_in_production"
JWT_EXPIRES_IN="7d"

# Google OAuth (Optional - required for Google Sign-In)
GOOGLE_CLIENT_ID=""

# Cloudinary Storage Configuration (Optional - fallback to base64 mock if empty)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Razorpay Payment Gateway (Optional - fallback to simulation mode if empty)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
